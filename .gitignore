# ---- Secrets / credentials (never commit) ----
# Belt-and-suspenders: this repo uses OIDC + the ephemeral GITHUB_TOKEN and is
# designed to contain no long-lived secrets. These patterns keep an accidental
# local key or env file from ever being staged.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
credentials.json
secrets.*
*.tfstate
*.tfstate.*

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# ---- Editors / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
._*

# ---- Agent guidance (internal scaffolding, not part of the public artifact) ----
CLAUDE.md
AGENTS.md

# ---- Personal study notes / explainers (not for the public artifact) ----
notes/

# ---- Misc ----
*.log
